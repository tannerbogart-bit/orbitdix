# ── Core ──────────────────────────────────────────────────────────────────────
# Set to False in production
DEBUG=True

# SQLite for local dev. Set to a PostgreSQL URL for production:
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///instance/orbitsix.db

# Flask session secret — protects OAuth CSRF state cookies
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# JWT signing secret
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me

# ── URLs ───────────────────────────────────────────────────────────────────────
# Base URL of the backend — used when building OAuth callback URIs
OAUTH_REDIRECT_BASE=http://localhost:5000

# Public URL of the frontend — used in emails and after OAuth redirects
FRONTEND_URL=http://localhost:5173

# ── AI ─────────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
# Leave blank in dev — emails are skipped and reset/verify links are printed to stdout
RESEND_API_KEY=

# Must be a verified sender domain in Resend
FROM_EMAIL=OrbitSix <noreply@orbitsix.ai>

# ── Cron ───────────────────────────────────────────────────────────────────────
# Secret header value for POST /api/admin/digest (weekly re-engagement emails)
# Set to any random string. Callers must send: X-Cron-Secret: <value>
# Leave blank to disable auth on the endpoint (dev only)
CRON_SECRET=

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe dashboard (Products → Add product → copy price ID)
STRIPE_PRO_PRICE_ID=
STRIPE_MAX_PRICE_ID=

# ── OAuth providers ───────────────────────────────────────────────────────────
# Callback URIs to register with each provider:
#   {OAUTH_REDIRECT_BASE}/api/auth/linkedin/callback
#   {OAUTH_REDIRECT_BASE}/api/auth/google/callback
#   {OAUTH_REDIRECT_BASE}/api/auth/microsoft/callback

# LinkedIn — https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, email
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google — https://console.cloud.google.com/apis/credentials
# Required scopes: openid, email, profile
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Supported account types: Accounts in any org directory + personal Microsoft accounts
# Required scopes: openid, email, profile, User.Read
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Chrome Extension ──────────────────────────────────────────────────────────
# Get from chrome://extensions after loading the extension in developer mode,
# or from the Chrome Web Store dashboard after publishing.
# Used to lock CORS — only this extension ID can call the API.
CHROME_EXTENSION_ID=
