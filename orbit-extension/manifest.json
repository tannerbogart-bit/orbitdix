{
  "manifest_version": 3,
  "name": "Orbit Six — LinkedIn Importer",
  "version": "1.1.0",
  "description": "Import your LinkedIn connections into Orbit Six",

  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://orbitsix.com/*",
    "https://*.orbitsix.com/*",
    "https://*.up.railway.app/*",
    "http://localhost:5000/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
